{
  "name": "fuelpro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "FuelPro - Fuel Station Management System",
  "author": "FuelPro",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.965.0",
    "@aws-sdk/s3-request-presigner": "^3.965.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^8.3.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.14.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.90.16",
    "@trpc/client": "^11.8.1",
    "@trpc/react-query": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "chart.js": "^4.5.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.13.0",
    "hono": "^4.12.23",
    "html2canvas": "^1.4.1",
    "jose": "6.1.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.510.0",
    "mysql2": "^3.14.1",
    "nanoid": "^5.1.6",
    "pako": "^2.1.0",
    "pdfjs-dist": "^5.6.205",
    "pkg": "^5.8.1",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.0.0",
    "react-router": "^7.5.3",
    "superjson": "^2.2.6",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.19.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.0.3",
    "@types/pako": "^2.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.8",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "globals": "15.15.0",
    "postcss": "^8.5.3",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.16"
  },
  "scripts": {
    "build": "vite build && esbuild api/boot.ts --platform=node --bundle --format=esm --outdir=dist --banner:js=\"import { createRequire } from 'module';const require = createRequire(import.meta.url);\"",
    "dev": "vite",
    "start": "NODE_ENV=production node dist/boot.js",
    "check": "tsc -b",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "electron": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win --x64",
    "electron:build:all": "npm run build && electron-builder --win --mac --linux",
    "cap:init": "npx cap init FuelPro com.fuelpro.app --web-dir dist",
    "cap:add:android": "npx cap add android",
    "cap:build": "npm run build && npx cap sync && cd android && ./gradlew assembleRelease"
  },
  "build": {
    "appId": "com.fuelpro.app",
    "productName": "FuelPro",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo-small.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FuelPro"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/logo-small.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/logo-small.png",
      "category": "Office"
    }
  }
}
