{
  "name": "fuelappmobile",
  "main": "frontend/src/worker/index.ts",
  "compatibility_date": "2026-05-29",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend/dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "cd frontend && npm install --legacy-peer-deps && npm run build"
  }
}
