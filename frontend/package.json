{
  "name": "fuelpro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "FuelPro - Fuel Station Management System",
  "author": "FuelPro",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.14.3",
    "@supabase/supabase-js": "^2.46.0",
    "@tanstack/react-query": "^5.90.16",
    "@trpc/client": "^11.8.1",
    "@trpc/react-query": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "chart.js": "^4.5.1",
    "cookie": "^0.6.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.13.0",
    "hono": "^4.8.3",
    "html2canvas": "^1.4.1",
    "jose": "6.1.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.510.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.6",
    "pako": "^2.1.0",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.0.0",
    "react-router": "^7.5.3",
    "superjson": "^2.2.6",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/vite-dev-server": "^0.19.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.0.3",
    "@types/pako": "^2.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "15.15.0",
    "postcss": "^8.5.3",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.16"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 0.0.0.0 --port 3000",
    "start": "vite --host 0.0.0.0 --port 3000",
    "check": "tsc -b",
    "format": "prettier --write .",
    "test": "vitest run",
    "electron": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win --x64",
    "electron:build:all": "npm run build && electron-builder --win --mac --linux",
    "cap:init": "npx cap init FuelPro com.fuelpro.app --web-dir dist",
    "cap:add:android": "npx cap add android",
    "cap:build": "npm run build && npx cap sync && cd android && ./gradlew assembleRelease"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.fuelpro.app",
    "productName": "FuelPro",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo-small.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FuelPro"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/logo-small.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/logo-small.png",
      "category": "Office"
    }
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    }
  }
}
