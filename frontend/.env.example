# ============================================================
# FuelPro Frontend — Environment Variables Reference
# Copy this file to .env.local (for local dev) or set in Vercel/Cloudflare.
# ALL variables MUST use the VITE_ prefix to be exposed by Vite at build time.
# ============================================================

# --- Backend API (REQUIRED for production) ---
# Vercel: Project Settings → Environment Variables
# Cloudflare: Workers → fuelappmobile → Settings → Variables
VITE_REACT_APP_BACKEND_URL=https://your-backend.example.com
# For local dev: VITE_REACT_APP_BACKEND_URL=http://localhost:8000

# --- Google OAuth ---
VITE_GOOGLE_CLIENT_ID=      # Web client ID from Google Cloud Console

# --- Stripe (publishable key — safe for frontend) ---
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# --- App meta ---
VITE_APP_NAME=FuelPro
VITE_APP_ENV=production     # production | development

# --- Push notifications (VAPID public key) ---
VITE_VAPID_PUBLIC_KEY=

# --- Feature flags ---
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
