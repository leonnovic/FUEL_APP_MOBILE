# FuelPro Environment Variables
# Copy this file to .env for local development
# Or set these variables in your deployment platform (Vercel, Render, Cloudflare)

# ============================================
# FOUNDER/ADMIN CREDENTIALS (REQUIRED - SERVER-SIDE ONLY)
# ============================================
# These are used for backend admin access - set strong, unique values!
# NEVER commit actual credentials to version control
FOUNDER_USERNAME=FOUNDER
FOUNDER_PASSWORD=your-secure-password-here
FOUNDER_DEFAULT_PASSWORD=your-secure-default-password

# ============================================
# BACKEND API CONFIGURATION (REQUIRED)
# ============================================
# The URL of your backend API server
# For production deployments on static hosts (Vercel, Render, Cloudflare Pages),
# your backend runs on a separate server, so this MUST be set.
VITE_REACT_APP_BACKEND_URL=https://your-backend.example.com
VITE_BACKEND_URL=https://your-backend.example.com

# ============================================
# GOOGLE OAUTH (REQUIRED FOR GOOGLE SIGN-IN)
# ============================================
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID (Web application)
# 2. Add authorized JavaScript origins for your domains
# 3. Copy the Client ID here
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ============================================
# SUPABASE CONFIGURATION (OPTIONAL)
# ============================================
# If using Supabase for authentication/database
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================
# FIREBASE CONFIGURATION (OPTIONAL - FOR CLOUD SYNC)
# ============================================
# If using Firebase for real-time cloud sync
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ============================================
# M-PESA CONFIGURATION (OPTIONAL - FOR KENYA PAYMENTS)
# ============================================
# Safaricom Daraja API credentials
VITE_MPESA_CONSUMER_KEY=your-mpesa-consumer-key
VITE_MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
VITE_MPESA_PASSKEY=your-mpesa-passkey
VITE_MPESA_SHORTCODE=your-mpesa-shortcode
VITE_MPESA_ENVIRONMENT=sandbox  # or 'production'

# ============================================
# STRIPE CONFIGURATION (OPTIONAL - FOR PAYMENTS)
# ============================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ============================================
# APPLICATION SETTINGS
# ============================================
VITE_APP_ENV=development  # or 'production'
VITE_APP_NAME=FuelPro
VITE_APP_VERSION=1.0.0

# ============================================
# AWS S3 CONFIGURATION (OPTIONAL - FOR FILE STORAGE)
# ============================================
VITE_AWS_REGION=us-east-1
VITE_AWS_S3_BUCKET=your-s3-bucket-name
# Note: AWS credentials should be set as server-side environment variables only
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY should NOT be exposed to the frontend

# ============================================
# PUSH NOTIFICATIONS (OPTIONAL)
# ============================================
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_CLOUD_SYNC=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_OFFLINE_MODE=true
