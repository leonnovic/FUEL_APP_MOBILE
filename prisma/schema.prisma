// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          String   @default("owner") // owner, manager, staff, auditor
  tier          String   @default("free")  // free, starter, pro, enterprise
  isGuest       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stations      StationMember[]
  sales         Sale[]
  shifts        Shift[]
}

model Station {
  id          String   @id @default(cuid())
  name        String
  location    String?
  phone       String?
  county      String?   // Kenya county
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     StationMember[]
  tanks       Tank[]
  sales       Sale[]
  shifts      Shift[]
  deliveries  Delivery[]
  reconciliations Reconciliation[]
  expenses    Expense[]
  invoices         Invoice[]
  employees        Employee[]
  documents        Document[]
  mpesaTransactions MpesaTransaction[]
  debts             Debt[]
  pumps             Pump[]
}

model StationMember {
  id        String   @id @default(cuid())
  userId    String
  stationId String
  role      String   @default("staff") // owner, manager, staff
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  station   Station  @relation(fields: [stationId], references: [id])

  @@unique([userId, stationId])
}

model Tank {
  id              String   @id @default(cuid())
  stationId       String
  fuelType        String   // Petrol, Diesel, Kerosene
  currentStock    Float    @default(0)    // liters
  capacity        Float    @default(0)    // liters
  pricePerLiter   Float    @default(0)    // KES
  alertThreshold  Float    @default(0)    // liters
  station         Station  @relation(fields: [stationId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Sale {
  id             String   @id @default(cuid())
  stationId      String
  userId         String
  fuelType       String
  quantityLiters Float
  pricePerLiter  Float
  totalAmount    Float
  paymentMethod  String   @default("cash") // cash, mpesa, card
  mpesaReceipt   String?
  customerName   String?
  station        Station  @relation(fields: [stationId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
}

model Shift {
  id              String   @id @default(cuid())
  stationId       String
  userId          String
  attendantName   String
  fuelType        String
  openingReading  Float    @default(0)
  closingReading  Float?
  litersSold      Float?
  cashCollected   Float?
  status          String   @default("active") // active, completed
  station         Station  @relation(fields: [stationId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
  startedAt       DateTime @default(now())
  endedAt         DateTime?
}

model Delivery {
  id            String   @id @default(cuid())
  stationId     String
  supplierName  String
  fuelType      String
  volumeLiters  Float
  costPerLiter  Float?
  totalCost     Float?
  deliveredAt   DateTime @default(now())
  station       Station  @relation(fields: [stationId], references: [id])
  createdAt     DateTime @default(now())
}

model Reconciliation {
  id              String   @id @default(cuid())
  stationId       String
  fuelType        String
  bookStock       Float
  physicalStock   Float
  deliveryReceived Float  @default(0)
  variance        Float
  variancePct     Float
  flag            String   @default("normal") // normal, warning, critical
  notes           String?
  station         Station  @relation(fields: [stationId], references: [id])
  recordedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
}

model EpraPrice {
  id          String   @id @default(cuid())
  fuelType    String
  region      String   @default("Nairobi")
  maxPrice    Float    // KES per liter
  effectiveAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fuelType, region, effectiveAt])
}

model ComplianceInvoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  sellerTin     String
  buyerTin      String?
  fuelType      String
  quantity      Float
  unitPrice     Float
  vatAmount     Float
  totalAmount   Float
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  meta      String?  // JSON string
  ip        String?
  createdAt DateTime @default(now())
}

model Coupon {
  id        String   @id @default(cuid())
  code      String   @unique
  type      String   @default("percentage") // percentage, fixed
  value     Float
  maxUses   Int      @default(100)
  uses      Int      @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contact     String?
  fuelTypes   String?  // comma separated
  location    String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  stationId   String
  category    String   // electricity, rent, salaries, maintenance, transport, other
  description String
  amount      Float
  date        DateTime @default(now())
  station     Station  @relation(fields: [stationId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  customerName  String
  customerEmail String?
  customerPhone String?
  items         String   // JSON string of line items: [{desc, qty, price, total}]
  subtotal      Float    @default(0)
  taxAmount     Float    @default(0)
  totalDue      Float    @default(0)
  status        String   @default("draft") // draft, sent, paid, cancelled
  dueDate       DateTime?
  issuedAt      DateTime @default(now())
  paidAt        DateTime?
  stationId     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  station       Station? @relation(fields: [stationId], references: [id])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  type      String   @default("customer") // customer, supplier, partner
  company   String?
  address   String?
  balance   Float    @default(0)  // outstanding balance in KES
  notes     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  position      String   // Station Manager, Cashier, Pump Attendant, Accountant
  basicSalary   Float    @default(0)
  houseAllow    Float    @default(0)
  transportAllow Float   @default(0)
  nhifDeduction Float    @default(0)
  nssfDeduction Float    @default(0)
  payeDeduction Float    @default(0)
  otherDeductions Float  @default(0)
  netPay        Float    @default(0)
  stationId     String?
  status        String   @default("active") // active, inactive, terminated
  dateJoined    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  station       Station? @relation(fields: [stationId], references: [id])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String   // license, contract, compliance, receipt, other
  fileType    String?  // pdf, jpg, png, etc
  size        String?  // file size string
  folder      String   @default("general") // licenses, contracts, compliance, receipts, general
  description String?
  url         String?  // file URL or local path
  stationId   String?
  uploadedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  station     Station? @relation(fields: [stationId], references: [id])
}

model MpesaTransaction {
  id              String   @id @default(cuid())
  phoneNumber     String   // +254 format
  amount          Float
  receiptNumber   String?  // M-Pesa receipt e.g. QKR3L5M7X9
  checkoutRequestId String?
  status          String   @default("pending") // pending, success, failed, cancelled
  resultDesc      String?
  stationId       String?
  saleId          String?  // Link to sale if created from sale
  merchantRequestId String?
  initiatedAt     DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  station         Station? @relation(fields: [stationId], references: [id])
}

model Debt {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String?
  amount        Float    // outstanding amount in KES
  fuelType      String?  // Petrol, Diesel, Kerosene
  stationId     String?
  status        String   @default("pending") // pending, partial, paid
  tillNumber    String?  // M-Pesa till for payment
  bankName      String?
  branchName    String?
  accountHolder String?
  accountNumber String?
  contactMethod String?  // phone, email, sms
  contactDetail String?  // actual phone/email
  dueDate       DateTime?
  notes         String?
  paidAmount    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  station       Station? @relation(fields: [stationId], references: [id])
}

model Pump {
  id              String   @id @default(cuid())
  stationId       String
  pumpLabel       String   // e.g. "Pump 1", "Pump A"
  fuelType        String   // Petrol, Diesel, Kerosene
  openingReading  Float    @default(0)  // in KES
  closingReading  Float    @default(0)  // in KES
  openingLiters   Float    @default(0)  // in Liters
  closingLiters   Float    @default(0)  // in Liters
  salesKsh        Float    @default(0)  // calculated: closing - opening in KES
  salesLiters     Float    @default(0)  // calculated: closing - opening in L
  shiftId         String?  // link to shift
  status          String   @default("idle") // idle, active, closed
  lastResetAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  station         Station  @relation(fields: [stationId], references: [id])
}

model CompanyProfile {
  id            String   @id @default(cuid())
  name          String   @default("FuelPro")
  logo          String?  // base64 or URL
  poBox         String?
  contacts      String?  // phone numbers
  email         String?
  bankName      String?
  branchName    String?
  accountHolder String?
  accountNumber String?
  currency      String   @default("KES")
  taxRate       Float    @default(16)  // VAT %
  receiptFooter String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
