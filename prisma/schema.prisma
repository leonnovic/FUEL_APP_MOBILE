// FuelPro - Fuel Management System
// Enhanced with RBAC, SOC-2 Audit Logs, Data Isolation, Cross-Device Sync
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── RBAC Enums ──────────────────────────────────────────────────────────────

// Action types for permission matrix
// create, read, update, delete, export, approve
// Data types: station, sale, inventory, employee, invoice, expense, audit_log, user, report, settings
// Team scopes: global, station, team, personal

// ─── User ────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // bcrypt hashed
  role      String   @default("staff") // founder, owner, manager, staff, auditor, guest
  tier      String   @default("free")  // free, pro, enterprise
  phone     String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stations       StationBinding[]
  auditLogs      AuditLog[]
  auditLogsActor AuditLogSoc2[]  @relation("AuditActor")
  documents      Document[]
  ownedStations  Station[]       @relation("StationOwner")
  sessions       Session[]
  permissions    Permission[]
  teamMembers    TeamMember[]
}

// ─── Session (Cross-Device Sync & Auth) ──────────────────────────────────────
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  deviceInfo String? // browser/device info
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Permission (RBAC Matrix) ────────────────────────────────────────────────
model Permission {
  id         String  @id @default(cuid())
  userId     String
  action     String  // create, read, update, delete, export, approve
  dataType   String  // station, sale, inventory, employee, invoice, expense, audit_log, user, report, settings
  teamScope  String  // global, station, team, personal
  stationId  String? // required if teamScope = station
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action, dataType, teamScope, stationId])
}

// ─── Team ────────────────────────────────────────────────────────────────────
model Team {
  id          String  @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TeamMember[]
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("member") // admin, member, viewer

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

// ─── Station ─────────────────────────────────────────────────────────────────
model Station {
  id        String   @id @default(cuid())
  name      String
  location  String
  country   String   @default("Kenya")
  currency  String   @default("KSH")
  ownerId   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User              @relation("StationOwner", fields: [ownerId], references: [id])
  bindings     StationBinding[]
  sales        Sale[]
  deliveries   Delivery[]
  invoices     Invoice[]
  clients      Client[]
  employees    Employee[]
  expenses     Expense[]
  shifts       Shift[]
  fuelTypes    FuelType[]
  suppliers    Supplier[]
  maintenance  Maintenance[]
  auditLogs    AuditLog[]
  auditLogsSoc2 AuditLogSoc2[]
  documents    Document[]
  payrolls        Payroll[]
  creditAccounts  CreditAccount[]
  paymentMethods  PaymentMethod[]
  qualityTests    QualityTest[]
  appSettings     AppSetting[]
  smsCampaigns    SmsCampaign[]
}

// ─── StationBinding (many-to-many User <-> Station) ─────────────────────────
model StationBinding {
  id        String   @id @default(cuid())
  userId    String
  stationId String
  role      String   @default("staff") // owner, manager, attendant, auditor
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  station Station  @relation(fields: [stationId], references: [id])

  @@unique([userId, stationId])
}

// ─── Sale ────────────────────────────────────────────────────────────────────
model Sale {
  id                 String   @id @default(cuid())
  stationId          String
  date               DateTime
  pmsOpeningReading  Float    @default(0)
  pmsClosingReading  Float    @default(0)
  agoOpeningReading  Float    @default(0)
  agoClosingReading  Float    @default(0)
  pmsPrice           Float    @default(0)
  agoPrice           Float    @default(0)
  pmsSalesKsh        Float    @default(0)
  agoSalesKsh        Float    @default(0)
  pmsSalesL          Float    @default(0)
  agoSalesL          Float    @default(0)
  totalSales         Float    @default(0)
  expenses           Float    @default(0)
  createdBy          String?
  createdAt          DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── Delivery ───────────────────────────────────────────────────────────────
model Delivery {
  id            String   @id @default(cuid())
  stationId     String
  date          DateTime
  supplier      String
  product       String   // PMS, AGO, etc.
  quantity      Float    @default(0)
  unitPrice     Float    @default(0)
  totalAmount   Float    @default(0)
  balanceDue    Float    @default(0)
  invoiceNumber String?
  driverName    String?
  vehicleNumber String?
  status        String   @default("pending") // pending, delivered, cancelled
  createdBy     String?
  createdAt     DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── Invoice ────────────────────────────────────────────────────────────────
model Invoice {
  id            String   @id @default(cuid())
  stationId     String
  clientName    String
  clientPhone   String?
  items         String   // JSON string: [{name, quantity, unitPrice, total}]
  totalAmount   Float    @default(0)
  status        String   @default("pending") // pending, paid, overdue, cancelled
  dueDate       DateTime?
  invoiceNumber String   @unique
  createdBy     String?
  createdAt     DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── Client ─────────────────────────────────────────────────────────────────
model Client {
  id          String   @id @default(cuid())
  stationId   String
  name        String
  phone       String?
  email       String?
  address     String?
  creditLimit Float    @default(0)
  balanceDue  Float    @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── Employee ───────────────────────────────────────────────────────────────
model Employee {
  id         String    @id @default(cuid())
  stationId  String
  name       String
  phone      String?
  role       String    // manager, attendant, accountant, etc.
  salary     Float     @default(0)
  hireDate   DateTime?
  status     String    @default("active") // active, inactive, terminated
  nationalId String?
  createdBy  String?
  createdAt  DateTime  @default(now())

  station Station @relation(fields: [stationId], references: [id])
  payrolls Payroll[]
}

// ─── Expense ────────────────────────────────────────────────────────────────
model Expense {
  id          String   @id @default(cuid())
  stationId   String
  date        DateTime
  category    String   // fuel, maintenance, salary, utilities, misc
  description String?
  amount      Float    @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── Shift ──────────────────────────────────────────────────────────────────
model Shift {
  id            String    @id @default(cuid())
  stationId     String
  date          DateTime
  attendantName String
  startTime     DateTime?
  endTime       DateTime?
  pmsOpening    Float     @default(0)
  pmsClosing    Float     @default(0)
  agoOpening    Float     @default(0)
  agoClosing    Float     @default(0)
  totalSales    Float     @default(0)
  cashDeclared  Float     @default(0)
  variance      Float     @default(0)
  status        String    @default("open") // open, closed, verified
  createdBy     String?
  createdAt     DateTime  @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── FuelType ───────────────────────────────────────────────────────────────
model FuelType {
  id           String   @id @default(cuid())
  stationId    String
  name         String   // PMS, AGO, DPK, etc.
  category     String   @default("fuel") // fuel, lubricant, gas
  price        Float    @default(0)
  tankCapacity Float    @default(0)
  currentLevel Float    @default(0)
  createdBy    String?
  createdAt    DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── Supplier ───────────────────────────────────────────────────────────────
model Supplier {
  id        String   @id @default(cuid())
  stationId String
  name      String
  phone     String?
  email     String?
  product   String?
  address   String?
  createdBy String?
  createdAt DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── Maintenance ────────────────────────────────────────────────────────────
model Maintenance {
  id            String    @id @default(cuid())
  stationId     String
  equipment     String
  description   String?
  status        String    @default("scheduled") // scheduled, in-progress, completed, cancelled
  priority      String    @default("medium") // low, medium, high, critical
  scheduledDate DateTime?
  completedDate DateTime?
  cost          Float     @default(0)
  assignedTo    String?
  createdBy     String?
  createdAt     DateTime  @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── AuditLog (Application-level, basic) ────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  stationId  String
  userId     String?
  action     String   // create, update, delete, login, logout, export, approve
  entityType String   // Sale, Delivery, Invoice, etc.
  entityId   String?
  details    String?  // JSON string for structured details
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
}

// ─── AuditLogSoc2 (SOC-2 Compliant, Immutable, Separate) ────────────────────
// Separate from app data - stores WHO did WHAT, WHERE, WHEN with integrity checks
model AuditLogSoc2 {
  id         String   @id @default(cuid())
  // WHO: Actor identification
  userId     String
  userEmail  String
  userRole   String
  sessionId  String?
  // WHAT: Action details
  action     String   // create, read, update, delete, login, logout, export, approve, read_denied
  resourceType String  // sale, station, user, invoice, etc.
  resourceId String?
  snapshotBefore String? // JSON string of resource before change
  snapshotAfter  String? // JSON string of resource after change
  payloadHash String?   // SHA-256 hash of request payload
  // WHERE: Context
  ipAddress  String   @default("unknown")
  userAgent  String   @default("unknown")
  stationId  String?
  teamId     String?
  // WHEN: Timestamps (immutable once written)
  timestamp  DateTime @default(now())
  // INTEGRITY: Immutability controls
  logSignature String? // HMAC-SHA256 of critical fields
  previousLogHash String? // Chain of hashes for tamper evidence
  logHash    String?  // SHA-256 of critical fields for indexing
  // METADATA
  reason     String?  // For denied actions
  createdAt  DateTime @default(now())

  station Station? @relation(fields: [stationId], references: [id])
  actor   User     @relation("AuditActor", fields: [userId], references: [id])
}

// ─── Document ───────────────────────────────────────────────────────────────
model Document {
  id         String   @id @default(cuid())
  stationId  String
  name       String
  type       String   // invoice, receipt, report, contract, etc.
  category   String?  // financial, operational, legal, etc.
  size       Int      @default(0)
  url        String
  uploadedBy String?
  createdAt  DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
  user    User?    @relation(fields: [uploadedBy], references: [id])
}

// ─── AppVersion (Prevent Frontend-Backend Mismatches) ────────────────────────
model AppVersion {
  id          String   @id @default(cuid())
  version     String   @unique // e.g., "1.2.3"
  buildNumber Int      @default(0)
  releaseNotes String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── Payroll (Kenya Compliance) ──────────────────────────────────────
model Payroll {
  id                String   @id @default(cuid())
  stationId         String
  employeeId        String
  payPeriodStart    DateTime
  payPeriodEnd      DateTime
  basicSalary       Float    @default(0)
  allowances        Float    @default(0)
  overtimeHours     Float    @default(0)
  overtimeRate      Float    @default(0)
  grossPay          Float    @default(0)
  shaDeduction      Float    @default(0)  // Social Health Authority - 2.75% of gross
  nssfDeduction     Float    @default(0)  // National Social Security Fund
  payeDeduction     Float    @default(0)  // Pay As You Earn tax
  advanceDeduction  Float    @default(0)
  otherDeductions   Float    @default(0)
  totalDeductions   Float    @default(0)
  netPay            Float    @default(0)
  paymentMethod     String   @default("bank_transfer") // bank_transfer, mpesa, cash
  paymentReference  String?
  status            String   @default("pending") // pending, processed, paid
  paidAt            DateTime?
  createdBy         String?
  createdAt         DateTime @default(now())

  station  Station  @relation(fields: [stationId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

// ─── CreditAccount (B2B Customers) ────────────────────────────────────
model CreditAccount {
  id              String   @id @default(cuid())
  stationId       String
  customerName    String
  contactPerson   String?
  phone           String?
  email           String?
  kraPin          String?
  creditLimit     Float    @default(0)
  balanceUsed     Float    @default(0)
  paymentTermsDays Int    @default(30)
  bankName        String?
  bankAccount     String?
  mpesaTill       String?
  status          String   @default("active") // active, suspended, closed
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── PaymentMethod (Multi-Country) ────────────────────────────────────
model PaymentMethod {
  id            String   @id @default(cuid())
  stationId     String
  type          String   // bank, mobile_money, card, digital_wallet, cash
  providerName  String   // Equity Bank, M-PESA, Visa, etc.
  accountNumber String?
  accountName   String?
  branchName    String?
  swiftCode     String?
  tillNumber    String?
  paybillNumber String?
  isActive      Boolean  @default(true)
  countryCode   String   @default("KE")
  createdBy     String?
  createdAt     DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── QualityTest (EPRA Standards) ─────────────────────────────────────
model QualityTest {
  id          String   @id @default(cuid())
  stationId   String
  date        DateTime
  batchNo     String?
  fuelType    String   // PMS, AGO, DPK
  density     Float?
  sulfur      Float?   // ppm
  flashPoint  Float?   // °C
  appearance  String?
  result      String   @default("pass") // pass, fail
  testedBy    String?
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}

// ─── AppSetting (Dynamic Configuration) ───────────────────────────────
model AppSetting {
  id        String   @id @default(cuid())
  stationId String
  category  String   // general, mpesa, sms, email, auth, compliance
  key       String
  value     String   // JSON string for complex values
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])

  @@unique([stationId, category, key])
}

// ─── SmsCampaign ──────────────────────────────────────────────────────
model SmsCampaign {
  id          String   @id @default(cuid())
  stationId   String
  type        String   @default("sms") // sms, email
  recipient   String
  subject     String?
  content     String
  status      String   @default("pending") // pending, sent, delivered, failed
  providerRef String?
  sentAt      DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id])
}
