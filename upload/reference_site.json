t=\"11\" x=\"3\" y=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg> Encrypted</span><span class=\"flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-wifi text-green-500\" aria-hidden=\"true\"><path d=\"M12 20h.01\"></path><path d=\"M2 8.82a15 15 0 0 1 20 0\"></path><path d=\"M5 12.859a10 10 0 0 1 14 0\"></path><path d=\"M8.5 16.429a5 5 0 0 1 7 0\"></path></svg> Any Device</span></div></div></div></div></div></div>\n    <script>\n      if ('serviceWorker' in navigator) {\n        window.addEventListener('load', () => {\n          navigator.serviceWorker.register('/sw.js').then((reg) => {\n            // Auto-check for app updates every 30 minutes\n            setInterval(() => { try { reg.update(); } catch (e) {} }, 30 * 60 * 1000);\n            // When a new SW is waiting, prompt to refresh\n            reg.addEventListener('updatefound', () => {\n              const next = reg.installing;\n              if (!next) return;\n              next.addEventListener('statechange', () => {\n                if (next.state === 'installed' && navigator.serviceWorker.controller) {\n                  // Dispatch a custom event so React can show an \"Update available\" toast\n                  window.dispatchEvent(new CustomEvent('fuelpro:update-ready', { detail: reg }));\n                }\n              });\n            });\n          }).catch(() => {});\n        });\n        // Reload once when a new SW takes control\n        let refreshing = false;\n        navigator.serviceWorker.addEventListener('controllerchange', () => {\n          if (refreshing) return;\n          refreshing = true;\n          window.location.reload();\n        });\n      }\n    </script>\n  \n\n</body></html>",
