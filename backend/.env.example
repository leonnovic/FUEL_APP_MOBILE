# ============================================================
# FuelPro Backend — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ============================================================

# --- Required ---
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=fuelpro
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# --- App environment ---
APP_ENV=production          # production | development
PUBLIC_BACKEND_URL=https://your-backend.example.com

# --- JWT settings ---
JWT_ALG=HS256
JWT_EXPIRE_HOURS=720        # 30 days

# --- Security ---
PASSWORD_PEPPER=replace-with-a-separate-random-pepper
MPESA_WEBHOOK_SECRET=       # Set to your Safaricom HMAC secret for callback verification

# --- M-PESA / Daraja ---
MPESA_ENV=production        # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_BASE_URL=https://your-backend.example.com

# --- Stripe ---
STRIPE_API_KEY=sk_live_...

# --- Google OAuth ---
GOOGLE_CLIENT_ID=           # Web client ID from Google Cloud Console
GOOGLE_CLIENT_SECRET=       # Not needed for token verification; required if using server-side flow

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@fuelpro.app

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Push notifications (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@fuelpro.app

# --- Founder / Ops ---
FOUNDER_EMAIL=founder@fuelpro.app
FOUNDER_DEFAULT_PASSWORD=   # Set a strong password; rotated after first login

# --- Feature flags ---
DIGEST_ENABLED=1            # 0 to disable daily digest cron
WATCHDOG_ENABLED=1          # 0 to disable health watchdog

# --- EPRA (Kenya fuel prices) ---
EPRA_API_KEY=               # Optional — for live price feed
