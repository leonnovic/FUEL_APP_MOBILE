{
  "version": 2,
  "buildCommand": "cd app && npm ci && npm run build:vercel",
  "outputDirectory": "app/dist",
  "framework": null,
  "functions": {
    "api/server.js": {
      "includeFiles": "api/handler.mjs",
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
